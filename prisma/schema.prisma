generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DEPARTMENT_OFFICER
  DATA_ENTRY
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum SchemeStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
  ON_HOLD
}

enum BeneficiaryStatus {
  IDENTIFIED
  VERIFIED
  APPROVED
  SUPPORTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                 Int          @id @default(autoincrement())
  fullName           String
  email              String       @unique
  password           String
  role               UserRole     @default(VIEWER)
  status             UserStatus   @default(ACTIVE)
  department         String?
  phone              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  createdSchemes     Scheme[]     @relation("SchemeCreatedBy")
  createdProjects    Project[]    @relation("ProjectCreatedBy")
  createdApprovals   Approval[]   @relation("ApprovalRequestedBy")
  reviewedApprovals  Approval[]   @relation("ApprovalReviewedBy")
}

model Scheme {
  id             Int          @id @default(autoincrement())
  title          String
  code           String       @unique
  description    String?
  department     String
  status         SchemeStatus @default(DRAFT)
  budget         Float        @default(0)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdById    Int?
  createdBy      User?        @relation("SchemeCreatedBy", fields: [createdById], references: [id])
  projects       Project[]
  beneficiaries  Beneficiary[]

  @@index([department])
  @@index([status])
}

model Project {
  id               Int           @id @default(autoincrement())
  name             String
  code             String        @unique
  description      String?
  department       String
  status           ProjectStatus @default(PLANNED)
  priority         PriorityLevel @default(MEDIUM)
  budget           Float         @default(0)
  beneficiaryCount Int           @default(0)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  schemeId         Int?
  createdById      Int?
  scheme           Scheme?       @relation(fields: [schemeId], references: [id], onDelete: SetNull)
  createdBy        User?         @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  beneficiaries    Beneficiary[]
  approvals        Approval[]

  @@index([department])
  @@index([status])
  @@index([priority])
}

model Beneficiary {
  id               Int               @id @default(autoincrement())
  fullName         String
  referenceNumber  String            @unique
  gender           String?
  district         String?
  block            String?
  status           BeneficiaryStatus @default(IDENTIFIED)
  sanctionedAmount Float             @default(0)
  phone            String?
  remarks          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  schemeId         Int?
  projectId        Int?
  approvedAt       DateTime?
  scheme           Scheme?           @relation(fields: [schemeId], references: [id], onDelete: SetNull)
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([district])
  @@index([status])
}

model Approval {
  id            Int            @id @default(autoincrement())
  title         String
  referenceNo   String         @unique
  entityType    String
  department    String
  status        ApprovalStatus @default(PENDING)
  priority      PriorityLevel  @default(MEDIUM)
  remarks       String?
  dueDate       DateTime?
  decisionAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  entityId      Int?
  projectId     Int?
  requestedById Int?
  reviewedById  Int?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestedBy   User?          @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  reviewedBy    User?          @relation("ApprovalReviewedBy", fields: [reviewedById], references: [id])

  @@index([department])
  @@index([status])
  @@index([priority])
}
