{
  "name": "jkcip-mis-backend",
  "version": "2.0.0",
  "description": "JKCIP MIS backend with dashboard, schemes, projects, beneficiaries, approvals and role-based access control.",
  "main": "dist/main.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "prisma:generate": "node node_modules/prisma/build/index.js generate",
    "prisma:push": "node node_modules/prisma/build/index.js db push",
    "prepare:deploy": "npm run prisma:generate && npm run build"
  },
  "keywords": [
    "nestjs",
    "prisma",
    "jkcip",
    "mis"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "5.19.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "5.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
